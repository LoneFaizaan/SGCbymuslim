{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A customer business inquiry lead",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique id of the inquiry" },
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "businessSection": { "type": "string", "enum": ["gold", "catering", "real_estate", "general"], "description": "The category/business division" },
        "message": { "type": "string", "description": "Customer custom message / requirement" },
        "date": { "type": "string", "description": "Local date of submission" },
        "syncedToSheets": { "type": "boolean", "description": "Whether it has been synced to Sheets" }
      },
      "required": ["id", "name", "phone", "businessSection", "message", "date"]
    }
  },
  "firestore": {
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of business inquiries"
    }
  }
}
