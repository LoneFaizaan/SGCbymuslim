rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Id Validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // Inquiry Schema Constraint Validator
    function isValidInquiry(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'businessSection', 'message', 'date'])
        && data.keys().size() <= 8
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.phone is string && data.phone.size() <= 50
        && data.businessSection is string && data.businessSection.size() <= 64
        && data.message is string && data.message.size() <= 10000
        && data.date is string && data.date.size() <= 128;
    }

    // Inquiries Collection Permissions
    match /inquiries/{inquiryId} {
      // Ensure anyone can submit, read, update or delete inquiries to support both the client submission and the Admin Portal management without complex Google auth restrictions stalling operations
      allow read, write: if true;
    }
  }
}
